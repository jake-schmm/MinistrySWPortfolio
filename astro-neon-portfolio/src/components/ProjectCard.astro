---
import { Code2, Gamepad2, Cpu, Rocket, Database, Boxes, ExternalLink } from 'lucide-astro';
const { project, slug } = Astro.props;
const icons = { Code2, Gamepad2, Cpu, Rocket, Database, Boxes };
const Icon = icons[project.data.icon] || Gamepad2;
---
<article class="project-card" data-reveal>
  <div class="project-image-wrap">
    <img src={project.data.image} alt={`${project.data.title} preview`} loading="lazy" />
    <div class="image-glow"></div>
  </div>
  <div class="project-card-body">
    <div class="project-icon"><Icon size={28} /></div>
    <h3>{project.data.title}</h3>
    <p>{project.data.description}</p>
    <div class="tags">
      {project.data.tags.map((tag) => <span>{tag}</span>)}
    </div>
    <div class="project-actions">
      <div class="button-row">
        <a class="btn btn-small" href={`/projects/${slug}/`}>View Case Study</a>
        <a class="icon-link" href={project.data.githubUrl} target="_blank" rel="noreferrer" aria-label="GitHub code">
          <ExternalLink size={18} /> Code
        </a>
      </div>
    </div>
  </div>
</article>
