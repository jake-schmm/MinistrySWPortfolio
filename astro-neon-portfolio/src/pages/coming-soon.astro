---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Coming Soon"
  description="A neon cyberpunk-style coming soon page for the portfolio."
>
  <main class="coming-wrapper">
    <div class="grid-bg"></div>
    <div class="glow glow-one"></div>
    <div class="glow glow-two"></div>

    <section class="coming-card">
      <p class="eyebrow">SYSTEM INITIALIZING</p>

      <h1>
        DEMO 
        <br/>COMING <span>SOON</span>
      </h1>

      <p class="description">
        Video and/or deployment in progress.
      </p>

      <div class="status-row">
        <div class="status-pill">
          <span class="dot"></span>
          Portfolio Expansion In Progress
        </div>
      </div>

      <div class="button-row">
        <a href="/" class="btn-primary">Return Home</a>
      </div>

      <div class="loading-section">
        <div class="loading-label">
          <span>Deploying Modules</span>
          <span>84%</span>
        </div>

        <div class="loading-bar">
          <div class="loading-progress"></div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  :root {
    --bg: #050816;
    --panel: rgba(10, 18, 38, 0.78);
    --cyan: #35f2ff;
    --green: #72ff7e;
    --orange: #ff8a3d;
    --text: #eef7ff;
    --muted: #8fa8c5;
    --border: rgba(255,255,255,0.08);
  }

  .coming-wrapper {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background:
      radial-gradient(circle at top left, rgba(53,242,255,0.12), transparent 28%),
      radial-gradient(circle at bottom right, rgba(114,255,126,0.10), transparent 24%),
      linear-gradient(180deg, #030712 0%, #050816 100%);
  }

  .grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: linear-gradient(to bottom, rgba(0,0,0,0.9), transparent);
    pointer-events: none;
  }

  .glow {
    position: absolute;
    border-radius: 999px;
    filter: blur(90px);
    opacity: 0.4;
    animation: pulse 6s ease-in-out infinite;
  }

  .glow-one {
    width: 260px;
    height: 260px;
    background: var(--cyan);
    top: 8%;
    left: 10%;
  }

  .glow-two {
    width: 320px;
    height: 320px;
    background: var(--green);
    bottom: 6%;
    right: 10%;
    animation-delay: 2s;
  }

  .coming-card {
    position: relative;
    z-index: 2;
    width: min(760px, 100%);
    border: 1px solid var(--border);
    background: var(--panel);
    backdrop-filter: blur(16px);
    border-radius: 28px;
    padding: 4rem;
    box-shadow:
      0 0 30px rgba(53,242,255,0.15),
      0 0 80px rgba(0,0,0,0.45);
    animation: floatCard 5s ease-in-out infinite;
  }

  .eyebrow {
    color: var(--cyan);
    font-size: 0.85rem;
    letter-spacing: 0.28rem;
    margin-bottom: 1.2rem;
    font-weight: 700;
  }

  h1 {
    margin: 0;
    color: var(--text);
    font-size: clamp(3rem, 8vw, 5.6rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
    text-shadow: 0 0 20px rgba(53,242,255,0.25);
  }

  h1 span {
    color: var(--green);
    text-shadow: 0 0 24px rgba(114,255,126,0.45);
  }

  .description {
    margin-top: 1.8rem;
    font-size: 1.08rem;
    line-height: 1.8;
    color: var(--muted);
    max-width: 640px;
  }

  .status-row {
    margin-top: 2rem;
  }

  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.85rem 1.2rem;
    border-radius: 999px;
    border: 1px solid rgba(114,255,126,0.28);
    background: rgba(114,255,126,0.08);
    color: #d8ffe0;
    font-size: 0.95rem;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: var(--green);
    box-shadow: 0 0 18px var(--green);
    animation: blink 1.4s infinite;
  }

  .button-row {
    margin-top: 2.2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .btn-primary,
  .btn-secondary {
    padding: 1rem 1.4rem;
    border-radius: 14px;
    text-decoration: none;
    font-weight: 700;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      background 0.25s ease;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--cyan), #00b7ff);
    color: #021018;
    box-shadow: 0 0 20px rgba(53,242,255,0.35);
  }

  .btn-secondary {
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.04);
    color: var(--text);
  }

  .btn-primary:hover,
  .btn-secondary:hover {
    transform: translateY(-3px) scale(1.02);
  }

  .btn-primary:hover {
    box-shadow: 0 0 30px rgba(53,242,255,0.55);
  }

  .loading-section {
    margin-top: 3rem;
  }

  .loading-label {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.7rem;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .loading-bar {
    height: 14px;
    border-radius: 999px;
    overflow: hidden;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.08);
  }

  .loading-progress {
    height: 100%;
    width: 84%;
    border-radius: inherit;
    background:
      linear-gradient(90deg, var(--cyan), var(--green), var(--orange));
    box-shadow: 0 0 18px rgba(53,242,255,0.45);
    animation: loadPulse 2.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% {
      transform: scale(1);
      opacity: 0.35;
    }
    50% {
      transform: scale(1.08);
      opacity: 0.55;
    }
  }

  @keyframes floatCard {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  @keyframes blink {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }

  @keyframes loadPulse {
    0%, 100% {
      filter: brightness(1);
    }
    50% {
      filter: brightness(1.25);
    }
  }

  @media (max-width: 720px) {
    .coming-card {
      padding: 2rem;
    }

    h1 {
      line-height: 1;
    }

    .button-row {
      flex-direction: column;
    }

    .btn-primary,
    .btn-secondary {
      text-align: center;
    }
  }
</style>
